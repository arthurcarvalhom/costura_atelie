# Configuração do Banco de Dados
# Copie este arquivo para .env e configure com suas credenciais

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=costura_atelier

# Configurações da Aplicação
SITE_URL=http://localhost/costura/
ADMIN_URL=http://localhost/costura/admin/

# Upload de Arquivos
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=assets/uploads/produtos/

# Sessão
SESSION_TIMEOUT=3600

# Email (para envios futuros)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu@email.com
MAIL_PASS=sua_senha

# WhatsApp
WHATSAPP_NUMERO=5511999999999

# Configurações de Segurança
JWT_SECRET=sua_chave_secreta_aqui
CSRF_TOKEN=csrf_token_aqui

# Modo Debug
DEBUG=true
